{
  "name": "cts-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.13.0+sha512.7119a16a0843580d65160977520e3f5710c974f04afd4fad36d9eb97d917ba716a856c35c78c4be6dc64367eeaccfb957ef5ce997ca31e9330b2e936ba2b1b92",
  "scripts": {
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --project=storybook --run",
    "lint:jsdoc": "bash scripts/lint-jsdoc-properties.sh",
    "lint:icons": "bash scripts/lint-icon-names.sh",
    "format": "prettier --config ./.prettierrc.json --write . ../src/main/resources/static/components",
    "format:check": "prettier --config ./.prettierrc.json --check . ../src/main/resources/static/components",
    "lint": "eslint ../frontend ../src/main/resources/static/components",
    "lint:fix": "eslint --fix ../frontend ../src/main/resources/static/components",
    "lint:lit-analyzer": "lit-analyzer \"../src/main/resources/static/components/**/cts-*.js\" --format list --rules.no-incompatible-type-binding warn --rules.no-nullable-attribute-binding warn",
    "type-check": "tsc --noEmit --pretty false -p tsconfig.json && tsc --noEmit --pretty false -p e2e/tsconfig.json",
    "codegen": "bash scripts/codegen.sh",
    "codegen:offline": "bash scripts/codegen.sh --offline",
    "codegen:check": "bash scripts/codegen.sh --check",
    "test:ci": "npm run format:check && npm run lint && npm run type-check && npm run lint:jsdoc && npm run lint:icons && npm run lint:lit-analyzer && npm run codegen:check",
    "test": "npm run test:ci && npm run test-storybook"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-mcp": "0.6.0",
    "@storybook/addon-vitest": "10.4.0",
    "@storybook/web-components-vite": "10.4.0",
    "@vitest/browser-playwright": "4.1.6",
    "dompurify": "3.4.7",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-lit": "2.3.1",
    "eslint-plugin-playwright": "2.10.2",
    "eslint-plugin-storybook": "10.4.0",
    "eslint-plugin-wc": "3.1.0",
    "globals": "17.6.0",
    "http-server": "14.1.1",
    "lit": "3.3.3",
    "lit-analyzer": "2.0.3",
    "marked": "18.0.4",
    "msw": "2.14.6",
    "openapi-typescript": "7.13.0",
    "playwright": "1.60.0",
    "prettier": "3.8.3",
    "quicktype": "23.2.6",
    "storybook": "10.4.0",
    "ts-lit-plugin": "2.0.2",
    "typescript": "5.9.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
