{
    "alias": "ssf-tx-test-dyn-ci",
    "description": "SSF Transmitter happy path against an emulated SSF Receiver using dynamic (client_secret_post) auth",
    "server": {
        "discoveryUrl": "{BASEURL}.well-known/oauth-authorization-server/test/a/ssf-rx-test-dyn-ci"
    },
    "client": {
        "client_id": "ssf-test-client",
        "client_secret": "ssf-test-secret",
        "scope": "ssf.read ssf.manage"
    },
    "ssf": {
        "subjects": {
            "valid": {
                "format": "opaque",
                "id": "valid"
            },
            "invalid": {
                "format": "opaque",
                "id": "invalid"
            }
        },
        "transmitter": {
            "issuer": "{BASEURL}",
            "metadata_suffix": "/test/a/ssf-rx-test-dyn-ci",
            "push_endpoint_authorization_header": "pushToken"
        }
    }
}
