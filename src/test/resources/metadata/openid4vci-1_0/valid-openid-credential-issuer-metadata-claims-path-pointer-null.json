{
    "credential_issuer": "https://issuer.example.com",
    "credential_endpoint": "https://issuer.example.com/credential",
    "credential_configurations_supported": {
        "mso_mdoc_mDL": {
            "format": "mso_mdoc",
            "scope": "mDL",
            "doctype": "org.iso.18013.5.1.mDL",
            "credential_metadata": {
                "claims": [
                    {
                        "path": ["org.iso.18013.5.1", "given_name"],
                        "mandatory": true
                    },
                    {
                        "path": ["org.iso.18013.5.1", "driving_privileges", null],
                        "mandatory": true
                    },
                    {
                        "path": ["org.iso.18013.5.1", "driving_privileges", null, "vehicle_category_code"],
                        "mandatory": true
                    }
                ]
            }
        },
        "dc_sd_jwt_education_degree": {
            "format": "dc+sd-jwt",
            "scope": "education_degree",
            "vct": "https://example.com/credentials/education_degree",
            "claims": [
                {
                    "path": ["degrees", null, "name"],
                    "mandatory": true
                },
                {
                    "path": ["degrees", 0],
                    "mandatory": false
                }
            ]
        }
    }
}
