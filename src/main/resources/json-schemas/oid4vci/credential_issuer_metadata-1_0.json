{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$comment": "https://openid.net/specs/openid-4-verifiable-credential-issuance-1_0.html",
    "type": "object",
    "properties": {
        "credential_issuer": {
            "type": "string"
        },
        "authorization_servers": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "credential_endpoint": {
            "type": "string",
            "format": "uri"
        },
        "nonce_endpoint": {
            "type": "string",
            "format": "uri"
        },
        "deferred_credential_endpoint": {
            "type": "string",
            "format": "uri"
        },
        "notification_endpoint": {
            "type": "string",
            "format": "uri"
        },
        "credential_request_encryption": {
            "$comment": "Per OID4VCI 1.0 Final section 12.2.4, 'jwks' is a JSON Web Key Set (object with a 'keys' array), not a bare array. The Appendix I example in the published spec incorrectly shows a bare array; see spec errata https://github.com/openid/OpenID4VCI/pull/711 ('JWKS format from array to object').",
            "type": "object",
            "properties": {
                "jwks": {
                    "type": "object",
                    "required": ["keys"],
                    "properties": {
                        "keys": {
                            "type": "array",
                            "minItems": 1,
                            "items": {
                                "$comment": "Recognised JWK parameters from RFC 7517 section 4 (common), RFC 7518 section 6 (EC/RSA/oct), and RFC 8037 (OKP). Unknown parameters are surfaced as warnings so typos and non-standard extensions are flagged.",
                                "type": "object",
                                "properties": {
                                    "kty": { "type": "string" },
                                    "use": { "type": "string" },
                                    "key_ops": { "type": "array", "items": { "type": "string" } },
                                    "alg": { "type": "string" },
                                    "kid": { "type": "string" },
                                    "x5u": { "type": "string" },
                                    "x5c": { "type": "array", "items": { "type": "string" } },
                                    "x5t": { "type": "string" },
                                    "x5t#S256": { "type": "string" },
                                    "crv": { "type": "string" },
                                    "x": { "type": "string" },
                                    "y": { "type": "string" },
                                    "d": { "type": "string" },
                                    "n": { "type": "string" },
                                    "e": { "type": "string" },
                                    "p": { "type": "string" },
                                    "q": { "type": "string" },
                                    "dp": { "type": "string" },
                                    "dq": { "type": "string" },
                                    "qi": { "type": "string" },
                                    "oth": { "type": "array" },
                                    "k": { "type": "string" }
                                },
                                "required": [
                                    "kid",
                                    "kty"
                                ],
                                "additionalProperties": false
                            }
                        }
                    },
                    "additionalProperties": false
                },
                "enc_values_supported": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string"
                    }
                },
                "encryption_required": {
                    "type": "boolean"
                },
                "zip_values_supported": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "jwks",
                "enc_values_supported",
                "encryption_required"
            ],
            "additionalProperties": false
        },
        "credential_response_encryption": {
            "type": "object",
            "properties": {
                "alg_values_supported": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string"
                    }
                },
                "enc_values_supported": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string"
                    }
                },
                "encryption_required": {
                    "type": "boolean"
                },
                "zip_values_supported": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": [
                "alg_values_supported",
                "enc_values_supported",
                "encryption_required"
            ],
            "additionalProperties": false
        },
        "batch_credential_issuance": {
            "type": "object",
            "properties": {
                "batch_size": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "required": [
                "batch_size"
            ],
            "additionalProperties": false
        },
        "signed_metadata": {
            "type": "string"
        },
        "display": {
            "type": "array",
            "items": {
                "$comment": "OID4VCI 1.0 Final section 12.2.4 says these display parameter lists are non-exhaustive. The conformance suite still warns on unknown members so typos and non-standard extensions are visible to testers; revisit if real-world feedback shows widely used extensions.",
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "locale": {
                        "type": "string"
                    },
                    "logo": {
                        "type": "object",
                        "properties": {
                            "uri": {
                                "type": "string",
                                "format": "uri"
                            },
                            "alt_text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "uri"
                        ],
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            }
        },
        "credential_configurations_supported": {
            "type": "object",
            "additionalProperties": {
                "$comment": "Use `unevaluatedProperties` rather than `additionalProperties` so that format-specific parameters defined in the `allOf`/`if`/`then` branches below (e.g. `vct` for dc+sd-jwt, `doctype` for mso_mdoc) are accepted when the matching branch fires. Properties that no matched branch defines are surfaced as warnings.",
                "unevaluatedProperties": false,
                "allOf": [
                    {
                        "type": "object",
                        "properties": {
                            "format": {
                                "type": "string"
                            },
                            "scope": {
                                "type": "string"
                            },
                            "cryptographic_binding_methods_supported": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "proof_types_supported": {
                                "type": "object",
                                "additionalProperties": {
                                    "type": "object",
                                    "properties": {
                                        "proof_signing_alg_values_supported": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        },
                                        "key_attestations_required": {
                                            "$comment": "OID4VCI 1.0 Final section 12.2.4 parameter; structure defined in Appendix D.",
                                            "type": "object"
                                        }
                                    },
                                    "required": [
                                        "proof_signing_alg_values_supported"
                                    ],
                                    "additionalProperties": false
                                }
                            },
                            "display": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "name": {
                                            "type": "string"
                                        },
                                        "locale": {
                                            "type": "string"
                                        },
                                        "logo": {
                                            "type": "object",
                                            "properties": {
                                                "uri": {
                                                    "type": "string",
                                                    "format": "uri"
                                                },
                                                "alt_text": {
                                                    "type": "string"
                                                }
                                            },
                                            "required": [
                                                "uri"
                                            ],
                                            "additionalProperties": false
                                        },
                                        "description": {
                                            "type": "string"
                                        },
                                        "background_color": {
                                            "type": "string"
                                        },
                                        "background_image": {
                                            "type": "object",
                                            "properties": {
                                                "uri": {
                                                    "type": "string",
                                                    "format": "uri"
                                                }
                                            },
                                            "required": [
                                                "uri"
                                            ],
                                            "additionalProperties": false
                                        },
                                        "text_color": {
                                            "type": "string"
                                        }
                                    },
                                    "additionalProperties": false
                                }
                            },
                            "credential_metadata": {
                                "type": "object",
                                "properties": {
                                    "display": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "name": {
                                                    "type": "string"
                                                },
                                                "locale": {
                                                    "type": "string"
                                                },
                                                "logo": {
                                                    "type": "object",
                                                    "properties": {
                                                        "uri": {
                                                            "type": "string",
                                                            "format": "uri"
                                                        },
                                                        "alt_text": {
                                                            "type": "string"
                                                        }
                                                    },
                                                    "required": [
                                                        "uri"
                                                    ],
                                                    "additionalProperties": false
                                                },
                                                "description": {
                                                    "type": "string"
                                                },
                                                "background_color": {
                                                    "type": "string"
                                                },
                                                "background_image": {
                                                    "type": "object",
                                                    "properties": {
                                                        "uri": {
                                                            "type": "string",
                                                            "format": "uri"
                                                        }
                                                    },
                                                    "required": [
                                                        "uri"
                                                    ],
                                                    "additionalProperties": false
                                                },
                                                "text_color": {
                                                    "type": "string"
                                                }
                                            },
                                            "additionalProperties": false
                                        }
                                    },
                                    "claims": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "path": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string"
                                                    },
                                                    "minItems": 1
                                                },
                                                "mandatory": {
                                                    "type": "boolean",
                                                    "default": false
                                                },
                                                "display": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object",
                                                        "properties": {
                                                            "name": {
                                                                "type": "string"
                                                            },
                                                            "locale": {
                                                                "type": "string",
                                                                "description": "BCP47 language tag."
                                                            }
                                                        },
                                                        "additionalProperties": false
                                                    }
                                                },
                                                "value_type": {
                                                    "type": "string"
                                                }
                                            },
                                            "required": [
                                                "path"
                                            ],
                                            "additionalProperties": false
                                        }
                                    }
                                },
                                "additionalProperties": false
                            }
                        },
                        "required": [
                            "format"
                        ]
                    },
                    {
                        "if": {
                            "properties": {
                                "format": {
                                    "const": "jwt_vc_json"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "credential_definition": {
                                    "type": "object",
                                    "description": "Object containing the detailed description of the Credential type.",
                                    "properties": {
                                        "type": {
                                            "type": "array",
                                            "description": "Array designating the types a certain Credential type supports.",
                                            "items": {
                                                "type": "string"
                                            }
                                        }
                                    },
                                    "required": [
                                        "type"
                                    ],
                                    "additionalProperties": false
                                },
                                "credential_signing_alg_values_supported": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            },
                            "required": [
                                "credential_definition"
                            ]
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "format": {
                                    "const": "dc+sd-jwt"
                                }
                            }
                        },
                        "then": {
                            "properties": {
                                "vct": {
                                    "type": "string",
                                    "description": "String designating the type of a Credential."
                                },
                                "credential_signing_alg_values_supported": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                },
                                "claims": {
                                    "type": "array",
                                    "description": "An array of claims description objects.",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "path": {
                                                "type": "array",
                                                "description": "A non-empty array representing a claims path pointer.",
                                                "items": {
                                                    "type": "string"
                                                },
                                                "minItems": 1
                                            },
                                            "mandatory": {
                                                "type": "boolean",
                                                "default": false
                                            },
                                            "display": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "name": {
                                                            "type": "string"
                                                        },
                                                        "locale": {
                                                            "type": "string",
                                                            "description": "BCP47 language tag."
                                                        }
                                                    },
                                                    "additionalProperties": false
                                                }
                                            }
                                        },
                                        "required": [
                                            "path"
                                        ],
                                        "additionalProperties": false
                                    }
                                }
                            },
                            "required": [
                                "vct"
                            ]
                        }
                    },
                    {
                        "if": {
                            "properties": {
                                "format": { "const": "mso_mdoc" }
                            }
                        },
                        "then": {
                            "properties": {
                                "doctype": {
                                    "type": "string",
                                    "description": "String identifying the Credential type (mdoc doctype)."
                                },
                                "credential_signing_alg_values_supported": {
                                    "type": "array",
                                    "items": {
                                        "oneOf": [
                                            { "type": "integer" }
                                        ]
                                    }
                                }
                            },
                            "required": ["doctype"]
                        }
                    }
                ]
            }
        }
    },
    "required": [
        "credential_issuer",
        "credential_endpoint",
        "credential_configurations_supported"
    ],
    "additionalProperties": false
}
