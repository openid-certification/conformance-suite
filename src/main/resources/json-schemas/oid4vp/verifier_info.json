{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$comment": "Validates the OID4VP verifier_info authorization request parameter. The schema's top level is a wrapper object so that the JsonSchemaValidationInput can be constructed (it requires a JsonObject); callers wrap the array in {\"verifier_info\": [...]}. See: https://openid.net/specs/openid-4-verifiable-presentations-1_0.html#section-5.1",
    "definitions": {
        "VerifierInfoEntry": {
            "type": "object",
            "properties": {
                "format": { "type": "string", "minLength": 1 },
                "data": { "type": ["string", "object"] },
                "credential_ids": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": { "type": "string", "minLength": 1 }
                }
            },
            "required": ["format", "data"],
            "additionalProperties": false
        }
    },
    "type": "object",
    "properties": {
        "verifier_info": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/VerifierInfoEntry" }
        }
    },
    "required": ["verifier_info"],
    "additionalProperties": false
}
